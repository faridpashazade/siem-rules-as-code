SPLUNK_URL=https://YOUR_SPLUNK_HOST:8089
SPLUNK_TOKEN=YOUR_SPLUNK_TOKEN_HERE
SPLUNK_AUTH_SCHEME=Bearer
SPLUNK_APP=search
SPLUNK_OWNER=nobody
SPLUNK_VERIFY_SSL=false
DRY_RUN=true

# QRadar API settings
QRADAR_URL=https://YOUR_QRADAR_HOST
QRADAR_TOKEN=YOUR_QRADAR_AUTHORIZED_SERVICE_TOKEN
QRADAR_API_VERSION=20.0
QRADAR_VERIFY_SSL=false
QRADAR_DRY_RUN=true
